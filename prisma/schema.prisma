// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pets      Pet[]
}

model Pet {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'cat', 'dog', 'rabbit', 'dragon'
  level       Int      @default(1)
  experience  Int      @default(0)
  hunger      Int      @default(80)
  happiness   Int      @default(80)
  health      Int      @default(100)
  energy      Int      @default(90)
  personality String
  mood        String   @default("happy") // 'happy', 'neutral', 'sad', 'excited', 'sleepy'
  coins       Int      @default(100)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  achievements PetAchievement[]
}

model Conversation {
  id        String   @id @default(cuid())
  petId     String
  sender    String   // 'user' or 'pet'
  message   String
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String @id @default(cuid())
  name        String
  description String
  icon        String
  requirement String
  reward      Int
  pets        PetAchievement[]
}

model PetAchievement {
  id            String @id @default(cuid())
  petId         String
  achievementId String
  unlockedAt    DateTime @default(now())
  pet           Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([petId, achievementId])
}